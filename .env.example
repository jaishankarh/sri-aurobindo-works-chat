# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Sri Aurobindo RAG"
DEBUG=false
LOG_LEVEL=INFO

# ── Database (PostgreSQL + pgvector) ─────────────────────────────────────────
# NOTE: host ports below match docker-compose.yml's mappings on this machine
# (5435/6380/7688/4201), remapped to avoid clashing with unrelated local services
# already bound to the 5432/6379/4200 defaults. Adjust if your setup differs.
DATABASE_URL=postgresql+asyncpg://rag:ragpassword@localhost:5435/rag_db

# ── Neo4j (knowledge graph store) ────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=aurobindo_graph

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380
REDIS_SESSION_TTL=86400

# ── Prefect Orchestration ────────────────────────────────────────────────────
PREFECT_API_URL=http://localhost:4201/api

# Embedding provider is independent of LLM provider — mix and match freely.
# All three keep EMBEDDING_DIM=1024 except "gemini" (see below), since
# "bge_m3" and "bge_m3_cloud" are literally the same model/vector space.
#
# EMBEDDING_PROVIDER options:
#   bge_m3       — local BAAI/bge-m3. Free, dense+sparse, CPU or GPU
#                  (EMBEDDING_DEVICE=cuda needs nvidia-container-toolkit on
#                  the Docker host — see backend/README notes). Recommended
#                  default: this is the only provider we've validated for
#                  Sanskrit/Devanagari retrieval quality in this corpus.
#   bge_m3_cloud — the *same* bge-m3 model hosted by a third-party inference
#                  provider (DeepInfra, Together AI, Fireworks, etc.) behind
#                  an OpenAI-compatible /v1/embeddings API. Same vector space
#                  as local bge_m3 (EMBEDDING_DIM stays 1024) — switching
#                  between "bge_m3" and "bge_m3_cloud" does NOT require
#                  re-ingestion. Dense only (no sparse/BM25 channel).
#   gemini       — Google's cloud embedding API. Dense only, and a DIFFERENT
#                  vector space/dimension than bge-m3 — switching to/from
#                  this provider requires dropping the `chunks` table and
#                  re-ingesting. Not yet validated for Sanskrit quality here;
#                  prefer bge_m3/bge_m3_cloud unless you've spot-checked it.

# ── Embedding: LOCAL bge_m3 (recommended default) ────────────────────────────
EMBEDDING_PROVIDER=bge_m3
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
# Device: "cpu", "cuda" (NVIDIA — needs nvidia-container-toolkit), "mps" (Apple Silicon)
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

# ── Embedding: CLOUD bge_m3 (same model, hosted) ─────────────────────────────
# EMBEDDING_PROVIDER=bge_m3_cloud
# EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_DIM=1024
# EMBEDDING_BASE_URL=https://api.your-inference-provider.com/v1
# EMBEDDING_API_KEY=...

# ── Embedding: CLOUD Gemini ───────────────────────────────────────────────────
# EMBEDDING_PROVIDER=gemini
# EMBEDDING_MODEL=gemini-embedding-001
# EMBEDDING_DIM=768
# GEMINI_API_KEY=...

# LLM_PROVIDER options: "ollama" (local, free, slow), "gemini", "openai", "anthropic"
# ── LLM: LOCAL Ollama ─────────────────────────────────────────────────────────
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
LLM_BASE_URL=http://localhost:11434

# ── LLM: CLOUD Gemini (recommended cloud default — fast, cheap, no local
# compute pressure; combine with the LOCAL bge_m3 embedding block above) ─────
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.5-flash
# GEMINI_API_KEY=...

# ── LLM: CLOUD OpenAI / Anthropic ─────────────────────────────────────────────
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...
#
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-5
# ANTHROPIC_API_KEY=sk-ant-...

# ── Corpus Data ───────────────────────────────────────────────────────────────
PDF_DIR=./data/pdfs
PROCESSED_DIR=./data/processed

# ── Frontend CORS ─────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3001", "http://localhost:5173"]
