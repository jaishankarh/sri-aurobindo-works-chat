# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Sri Aurobindo RAG"
DEBUG=false
LOG_LEVEL=INFO

# ── Database (PostgreSQL + pgvector) ─────────────────────────────────────────
# NOTE: host ports below match docker-compose.yml's mappings on this machine
# (5435/6380/7688/4201), remapped to avoid clashing with unrelated local services
# already bound to the 5432/6379/4200 defaults. Adjust if your setup differs.
DATABASE_URL=postgresql+asyncpg://rag:ragpassword@localhost:5435/rag_db

# ── Neo4j (knowledge graph store) ────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=aurobindo_graph

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380
REDIS_SESSION_TTL=86400

# ── Prefect Orchestration ────────────────────────────────────────────────────
PREFECT_API_URL=http://localhost:4201/api

# ── Embedding Model ──────────────────────────────────────────────────────────
# Model: BAAI/bge-m3 (100+ languages, dense + sparse, open source)
EMBEDDING_MODEL=BAAI/bge-m3
# Device: "cpu", "cuda" (NVIDIA), "mps" (Apple Silicon M-series)
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Provider: "ollama" (local), "openai", "anthropic"
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
LLM_BASE_URL=http://localhost:11434

# For cloud LLM providers (optional):
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── Corpus Data ───────────────────────────────────────────────────────────────
PDF_DIR=./data/pdfs
PROCESSED_DIR=./data/processed

# ── Frontend CORS ─────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3001", "http://localhost:5173"]
