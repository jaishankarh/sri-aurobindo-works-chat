# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Sri Aurobindo RAG"
DEBUG=false
LOG_LEVEL=INFO

# ── Database (PostgreSQL + pgvector) ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://rag:ragpassword@localhost:5432/rag_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_SESSION_TTL=86400

# ── Prefect Orchestration ────────────────────────────────────────────────────
PREFECT_API_URL=http://localhost:4200/api

# ── Embedding Model ──────────────────────────────────────────────────────────
# Model: BAAI/bge-m3 (100+ languages, dense + sparse, open source)
EMBEDDING_MODEL=BAAI/bge-m3
# Device: "cpu", "cuda" (NVIDIA), "mps" (Apple Silicon M-series)
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Provider: "ollama" (local), "openai", "anthropic"
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
LLM_BASE_URL=http://localhost:11434

# For cloud LLM providers (optional):
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── Corpus Data ───────────────────────────────────────────────────────────────
PDF_DIR=./data/pdfs
PROCESSED_DIR=./data/processed

# ── Frontend CORS ─────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]
